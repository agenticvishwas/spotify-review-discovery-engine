# Copy this file's contents into Streamlit Cloud → App settings → Secrets.
# Do NOT commit the real secrets.toml — it is gitignored.

# At least one LLM provider is required for the NL Query page (page 6).
# Leave unused keys blank or remove them entirely.

ANTHROPIC_API_KEY = "sk-ant-..."
GROQ_API_KEY = "gsk_..."

# Ollama cannot run on Streamlit Cloud (no local server). Leave these unset.
# OLLAMA_BASE_URL = "http://localhost:11434"
# OLLAMA_MODEL    = "qwen2.5:3b"

# Optional overrides
# LLM_MODEL    = "claude-sonnet-4-6"
# GROQ_MODEL   = "llama-3.3-70b-versatile"
# LLM_STRATEGY = "failover"
